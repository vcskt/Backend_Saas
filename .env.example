# Arquivo de ambiente para PRODUÇÃO na VPS
# Copie este arquivo como '.env' na VPS e preencha os valores reais
# NUNCA comite o .env com valores reais no Git!

# ─── Banco de Dados ───────────────
POSTGRES_USER=vcskt_db
POSTGRES_PASSWORD=SUA_SENHA_SEGURA_AQUI
POSTGRES_DB=blackjag_db

# Prisma usa este formato para conectar internamente na rede Docker
DATABASE_URL=postgresql://vcskt_db:SUA_SENHA_SEGURA_AQUI@db:5432/blackjag_db?schema=public

# ─── JWT ──────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=SUA_CHAVE_JWT_MUITO_LONGA_E_ALEATORIA_AQUI

# ─── CORS ─────────────────────────
# URL pública do seu frontend Angular (sem barra no final)
FRONTEND_URL=https://blackjag.com.br

# ─── Porta da API ─────────────────
PORT=3000
